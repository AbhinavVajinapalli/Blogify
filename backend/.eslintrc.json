{
  "root": true,
  "env": {
    "es2021": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "module"
  },
  "extends": [
    "eslint:recommended"
  ],
  "rules": {
    "no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_"
      }
    ],
    "no-console": [
      "warn",
      {
        "allow": [
          "warn",
          "error"
        ]
      }
    ],
    "prefer-const": "warn",
    "no-var": "error",
    "eqeqeq": [
      "warn",
      "always"
    ],
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "no-extend-native": "error",
    "no-multi-spaces": "warn",
    "no-param-reassign": [
      "warn",
      {
        "props": false
      }
    ],
    "no-return-assign": "warn",
    "no-sequences": "warn",
    "yoda": [
      "warn",
      "never"
    ]
  }
}
